<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.social.mapper.UserMapper">
  <resultMap id="UserMap" type="com.example.social.entity.User">
    <id property="id" column="id"/>
    <result property="username" column="username"/>
    <result property="nickname" column="nickname"/>
    <result property="passwordHash" column="password_hash"/>
    <result property="avatarUrl" column="avatar_url"/>
    <result property="bio" column="bio"/>
    <result property="role" column="role"/>
    <result property="status" column="status"/>
    <result property="createdAt" column="created_at"/>
    <result property="updatedAt" column="updated_at"/>
  </resultMap>

  <select id="findByUsername" resultMap="UserMap">
    SELECT * FROM users WHERE username = #{username}
  </select>

  <select id="findById" resultMap="UserMap">
    SELECT * FROM users WHERE id = #{id}
  </select>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO users (username, nickname, password_hash, avatar_url, bio, role, status, created_at, updated_at)
    VALUES (#{username}, #{nickname}, #{passwordHash}, #{avatarUrl}, #{bio}, #{role}, #{status}, #{createdAt}, #{updatedAt})
  </insert>

  <update id="updateProfile">
    UPDATE users
    SET nickname = #{nickname}, bio = #{bio}, avatar_url = #{avatarUrl}, updated_at = NOW()
    WHERE id = #{id}
  </update>

  <select id="countUsers" resultType="int">
    SELECT COUNT(*) FROM users
  </select>

  <select id="countReceivedLikes" resultType="int">
    SELECT COUNT(*)
    FROM likes l
    JOIN posts p ON p.id = l.post_id
    WHERE p.user_id = #{id}
  </select>
</mapper>
