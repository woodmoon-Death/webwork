<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.social.mapper.CommentMapper">
  <resultMap id="CommentMap" type="com.example.social.entity.Comment">
    <id property="id" column="id"/>
    <result property="postId" column="post_id"/>
    <result property="userId" column="user_id"/>
    <result property="content" column="content"/>
    <result property="createdAt" column="created_at"/>
    <result property="updatedAt" column="updated_at"/>
  </resultMap>

  <resultMap id="CommentVoMap" type="com.example.social.vo.CommentVo">
    <id property="id" column="id"/>
    <result property="postId" column="post_id"/>
    <result property="userId" column="user_id"/>
    <result property="authorName" column="author_name"/>
    <result property="avatarUrl" column="avatar_url"/>
    <result property="content" column="content"/>
    <result property="createdAt" column="created_at"/>
  </resultMap>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO comments (post_id, user_id, content, created_at, updated_at)
    VALUES (#{postId}, #{userId}, #{content}, #{createdAt}, #{updatedAt})
  </insert>

  <delete id="deleteById">
    DELETE FROM comments WHERE id = #{id}
  </delete>

  <select id="findEntityById" resultMap="CommentMap">
    SELECT * FROM comments WHERE id = #{id}
  </select>

  <select id="findByPostId" resultMap="CommentVoMap">
    SELECT c.id, c.post_id, c.user_id, u.nickname AS author_name, u.avatar_url, c.content, c.created_at
    FROM comments c
    JOIN users u ON u.id = c.user_id
    WHERE c.post_id = #{postId}
    ORDER BY c.created_at ASC
  </select>

  <select id="countComments" resultType="int">
    SELECT COUNT(*) FROM comments
  </select>
</mapper>
